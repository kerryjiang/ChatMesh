<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AIChatMesh.MauiClient.Pages.SettingsPage"
             Title="Settings">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Label Text="Server Settings"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Label Text="Server Host" />
            <Entry x:Name="ServerHostEntry"
                   Placeholder="localhost:4040" />

            <Label Text="Username" />
            <Entry x:Name="UsernameEntry"
                   Placeholder="Enter your username" />

            <Label Text="Authentication Token" />
            <Entry x:Name="TokenEntry"
                   Placeholder="Enter your token"
                   IsPassword="True" />

            <Label Text="Peer Username" />
            <Entry x:Name="PeerUsernameEntry"
                   Placeholder="Enter peer username" />

            <Button Text="Save"
                    Clicked="OnSaveClicked"
                    Margin="0,20,0,0" />

            <Label x:Name="SavedLabel"
                   Text=""
                   TextColor="Green"
                   IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
